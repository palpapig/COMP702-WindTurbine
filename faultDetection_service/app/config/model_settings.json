{
  "default_target_column": "Power (kW)",
  "default_feature_columns": [
    "Wind speed (m/s)",
    "Drive train acceleration (mm/ss)",
    "Gear oil inlet temperature (°C)",
    "Transformer temperature (°C)",
    "Front bearing temperature (°C)",
    "Tower Acceleration y (mm/ss)",
    "Nacelle temperature (°C)",
    "Gear oil temperature (°C)"
  ],
  "model_type": "knn_bagging",
  "test_size": 0.2,
  "random_state": 42,
  "scale_features": true,
  "minimum_training_rows": 200,
  "retrain_interval_days": 90,
  "alarm": {
    "ewma_lambda": 0.2,
    "control_limit_k": 3.0,
    "a2_consecutive_a1_count": 3
  },
  "knn_bagging": {
    "n_neighbors": 13,
    "weights": "distance",
    "metric": "manhattan",
    "n_estimators": 30
  }
}
